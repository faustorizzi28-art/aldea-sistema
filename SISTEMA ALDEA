  .ep-alerta.pronto{color:var(--amarillo);}
  .ep-alerta.ok{color:var(--verde);}
  .ev-prox-obs{padding:0 14px 10px;font-size:11px;color:var(--gris);font-style:italic;}

  .sync-bar{display:flex;align-items:center;justify-content:space-between;padding:8px 16px;background:var(--azul-claro);margin:0 0 4px;}
  .sync-bar span{font-size:12px;color:var(--azul);}
  .sync-bar button{background:var(--azul);color:white;border:none;border-radius:7px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;}
