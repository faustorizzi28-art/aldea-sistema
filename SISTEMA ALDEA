    ${oi>0?`<div class="fila chico"><span class="izq">Otros ingresos</span><span class="der">${fmtT(oi)}</span></div>`:''}
    <hr class="sep"/>
    <div class="fila bold"><span class="izq">TOTAL INGRESOS</span><span class="der">${fmtT(totalIn)}</span></div>

    <hr class="sep" style="margin-top:6px;"/>
    <div class="bold chico" style="margin:3px 0;">EGRESOS</div>
    ${egresosLineas || '<div class="chico" style="color:#666;">Sin egresos registrados</div>'}
