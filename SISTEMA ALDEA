  .btn-azul{background:var(--azul);color:white;}
  .btn-copy-azul{background:none;border:1.5px solid var(--azul);color:var(--azul);border-radius:8px;padding:10px 16px;font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;width:100%;margin-bottom:8px;}

  /* ══ CANCHAS RESERVAS (tab combinado) ══ */  
  .canchasres-tabs{display:flex;gap:0;padding:12px 16px 0;}
  .cr-tab{flex:1;padding:8px 6px;font-size:12px;font-weight:600;text-align:center;cursor:pointer;color:var(--gris);border-bottom:2px solid var(--borde);transition:all .2s;}
  .cr-tab.active{color:var(--naranja);border-bottom:2px solid var(--naranja);}
  .cr-view{display:none;}.cr-view.active{display:block;}


  /* ══ GRILLA TURNOS FIJOS ══ */
  .tf-section{background:white;border-radius:14px;border:1px solid var(--borde);margin:12px 16px;overflow:hidden;}
  .tf-header{background:var(--gris-oscuro);color:white;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;}
  .tf-header h3{font-size:13px;font-weight:600;letter-spacing:.04em;}
  .tf-header button{background:rgba(255,255,255,.15);border:none;color:white;border-radius:7px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;}
  .tf-grid{overflow-x:auto;}
  .tf-table{width:100%;border-collapse:collapse;min-width:520px;}
  .tf-table th{background:var(--gris-claro);font-size:11px;font-weight:700;color:var(--gris);text-align:center;padding:8px 6px;border-bottom:1px solid var(--borde);letter-spacing:.04em;text-transform:uppercase;position:sticky;top:0;}
  .tf-table th.hora-col{text-align:left;padding-left:12px;min-width:60px;}
  .tf-table td{border-bottom:1px solid var(--gris-claro);padding:0;vertical-align:top;min-width:90px;}
  .tf-table td.hora-cell{padding:10px 8px 10px 12px;font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--gris);background:var(--gris-claro);border-right:2px solid var(--borde);white-space:nowrap;vertical-align:middle;}
  .tf-table tr:last-child td{border-bottom:none;}
  .tf-slot{padding:6px 8px;min-height:56px;cursor:pointer;transition:background .15s;position:relative;}
