// Override renderProximos with improved version
function renderProximos(lista) {
  const hoy = new Date(); hoy.setHours(0,0,0,0);

  // Filtrar
  let filtrada = lista.slice();
  if (filtroProxActual === 'hoy') {
    filtrada = filtrada.filter(e => diasHastaFecha(e.fecha) === 0);
  } else if (filtroProxActual === 'semana') {
    filtrada = filtrada.filter(e => {
      const d = diasHastaFecha(e.fecha); return d >= 0 && d <= 7;
    });
  } else if (filtroProxActual === 'mes') {
    filtrada = filtrada.filter(e => {
      const d = diasHastaFecha(e.fecha); return d >= 0 && d <= 30;
    });
  } else if (filtroProxActual === 'pileta') {
    filtrada = filtrada.filter(e => e.pileta === 'Si');
  } else if (filtroProxActual !== 'todos') {
    filtrada = filtrada.filter(e => e.estado === filtroProxActual);
  }

  // KPIs
  const saldoTotal = lista.reduce((a,e) => a + Math.max(0,(e.monto||0)-(e.senia||0)), 0);
  const semana = lista.filter(e => { const d=diasHastaFecha(e.fecha); return d>=0&&d<=7; }).length;
  document.getElementById('pk-total').textContent   = lista.length;
  document.getElementById('pk-saldo').textContent   = fmtProx(saldoTotal);
  document.getElementById('pk-semana').textContent  = semana;

  const container = document.getElementById('prox-lista');
  if (!container) return;

  if (filtrada.length === 0) {
    container.innerHTML = `<div style="text-align:center;padding:52px 20px;color:var(--gris);">
      <div style="font-size:48px;margin-bottom:14px;">📅</div>
      <div style="font-size:14px;font-weight:500;margin-bottom:6px;">No hay eventos que coincidan</div>
      <div style="font-size:12px;">Tocá "🔄 Actualizar" para traer datos de Sheets</div>
    </div>`;
    return;
  }

  const MESES_L = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const MESES_S = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  const DIAS_S  = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];

  const parts = [];
  let mesActual = '';

  filtrada.forEach(ev => {
    const d = new Date(ev.fecha + 'T12:00:00');
    const dias = diasHastaFecha(ev.fecha);
    const saldo = Math.max(0, (ev.monto||0) - (ev.senia||0));
    const mesKey = `${d.getFullYear()}-${d.getMonth()}`;

    // Separador de mes
    if (mesKey !== mesActual) {
      mesActual = mesKey;
      parts.push(`<div class="evp-mes-header">
        <div class="evp-mes-line"></div>
        <div class="evp-mes-label">${MESES_L[d.getMonth()].toUpperCase()} ${d.getFullYear()}</div>
        <div class="evp-mes-line" style="flex:1;height:1px;background:var(--borde);margin-left:10px;"></div>
      </div>`);
    }

    // Clase de urgencia
    let urgCls = dias <= 0 ? '' : dias <= 1 ? 'hoy' : dias <= 7 ? 'pronto' : ev.estado === '🟢 Confirmado' ? 'confirmado' : '';

    // Badge de días
    let diasBadge = '';
    if (dias < 0) diasBadge = `<div class="ef-dias-badge" style="background:var(--gris-claro);color:var(--gris);">Pasado</div>`;
    else if (dias === 0) diasBadge = `<div class="ef-dias-badge" style="background:var(--rojo);color:white;">HOY</div>`;
    else if (dias === 1) diasBadge = `<div class="ef-dias-badge" style="background:var(--rojo-claro);color:var(--rojo);">Mañana</div>`;
    else if (dias <= 7) diasBadge = `<div class="ef-dias-badge" style="background:var(--amarillo-claro);color:var(--amarillo);">${dias} días</div>`;
    else diasBadge = `<div class="ef-dias-badge" style="background:var(--verde-claro);color:var(--verde);">${dias} días</div>`;

    // Turno label
    const turnoLabel = ev.turno === 'M' ? '🌅 Mañana' : ev.turno === 'T' ? '🌆 Tarde' : ev.turno === 'N' ? '🌙 Noche' : (ev.turno||'');

    // Estado style
    const estMap = {
      '🔵 Consulta nueva': 'background:#DBEAFE;color:#1A5F9E',
      '🟠 Esperando seña': 'background:#FEF3E7;color:#E67E22',
      '🟢 Confirmado': 'background:#E8F5EF;color:#1A7A55',
      '🟣 Recordatorio enviado': 'background:#F3E8FF;color:#6A0DAD',
      '⚫ Finalizado': 'background:#F2F2F2;color:#6B6B6B',
      '❌ Cancelado': 'background:#FDECEA;color:#C0392B',
    };
    const estStyle = estMap[ev.estado] || 'background:#F2F2F2;color:#6B6B6B';

    // WhatsApp message
    const fechaTxt = `${DIAS_S[d.getDay()]} ${d.getDate()}/${d.getMonth()+1}`;
    const waMsgEnc = encodeURIComponent(`¡Hola ${ev.nombre}! 👋\n\nTe recordamos tu evento en *Aldea del Valle*:\n📅 *${fechaTxt}*\n🕐 *${ev.horarioIni||''} a ${ev.horarioFin||''} hs*\n🎉 *${ev.tipo}*${ev.pileta==='Si'?'\n🏊 Con pileta':''}${saldo>0?'\n\n💰 *Saldo pendiente: '+fmtProx(saldo)+'*':''}\n\n¡Los esperamos! 🌿`);
    const telLimpio = (ev.tel||'').replace(/\D/g,'');
    const waUrl = `https://wa.me/${telLimpio?'54'+telLimpio:''}?text=${waMsgEnc}`;

    parts.push(`
    <div class="evp-card ${urgCls}">
      <div class="evp-top">
        <div class="evp-fecha-col">
          <div class="ef-num">${d.getDate()}</div>
          <div class="ef-mes">${MESES_S[d.getMonth()]}</div>
          <div class="ef-dia">${DIAS_S[d.getDay()]}</div>
          ${diasBadge}
        </div>
        <div class="evp-body">
          <div class="evp-nombre">${ev.nombre || '—'}</div>
          <div class="evp-chips">
            ${ev.turno ? `<span class="evp-chip turno">${turnoLabel}</span>` : ''}
            ${ev.tipo ? `<span class="evp-chip tipo">${ev.tipo}</span>` : ''}
            ${ev.pileta === 'Si' ? `<span class="evp-chip pileta">🏊 Pileta</span>` : ''}
          </div>
          ${(ev.horarioIni||ev.horarioFin) ? `<div class="evp-horario">🕐 ${ev.horarioIni||''} – ${ev.horarioFin||''} hs</div>` : ''}
          ${ev.tel ? `<div class="evp-tel">📱 ${ev.tel}</div>` : ''}
          ${ev.monto ? `<div class="evp-montos-row">
            <div class="evp-monto-box"><div class="emb-lbl">Total</div><div class="emb-val" style="color:var(--azul)">${fmtProx(ev.monto)}</div></div>
            <div class="evp-monto-box"><div class="emb-lbl">Seña</div><div class="emb-val" style="color:var(--verde)">${fmtProx(ev.senia||0)}</div></div>
            <div class="evp-monto-box"><div class="emb-lbl">Saldo</div><div class="emb-val" style="color:${saldo>0?'var(--rojo)':'var(--verde)'};font-weight:700">${fmtProx(saldo)}</div></div>
          </div>` : ''}
        </div>
      </div>
      ${ev.obs ? `<div class="evp-obs">📝 ${ev.obs}</div>` : ''}
      <div class="evp-footer">
        <span class="evp-estado" style="${estStyle}">${ev.estado}</span>
      </div>
      <div class="evp-acciones">
        ${ev.tel ? `<button class="evp-btn wa" onclick="window.open('${waUrl}','_blank')">📱 WhatsApp</button>` : ''}
        <button class="evp-btn edit" onclick="cambiarModulo('eventos',document.querySelector('.tab:nth-child(3))');setTimeout(()=>abrirModalEvento(eventos.findIndex(e=>e.fecha==='${ev.fecha}'&&e.nombre==='${ev.nombre.replace(/'/g,"\\'")}'")),200)">✏️ Editar</button>
      </div>
    </div>`);
  });

  container.innerHTML = parts.join('');
}

