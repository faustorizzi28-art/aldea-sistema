  .ep-chip.tipo{background:var(--azul-claro);color:var(--azul);}
  .ep-chip.pileta{background:var(--verde-claro);color:var(--verde);}
  .ep-chip.tel{background:var(--gris-claro);color:var(--gris);}
  .ev-prox-horario{font-size:12px;color:var(--gris);margin-bottom:6px;}
