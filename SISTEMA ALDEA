      const turno = turnosFijos.find(t => t.diaIdx === diaIdx && t.hora === hora);
      const div = document.createElement('div');
      div.className = 'tf-slot' + (turno ? ' ocupado' : '');
      div.onclick = () => abrirModalTF(diaIdx, hora, turno || null);

      if (turno) {
        div.innerHTML = `
          <div class="tf-slot-nombre">${turno.nombre}</div>
          <div class="tf-slot-tel">📱 ${turno.tel || '—'}</div>
          <div class="tf-slot-monto">${turno.monto ? fmt(turno.monto)+'/mes' : ''}</div>
          ${turno.cancha ? `<div style="font-size:9px;color:var(--gris);margin-top:2px;">⚽ ${turno.cancha}</div>` : ''}`;
        td.style.background = TF_COL[diaIdx] + '88';
      } else {
        div.innerHTML = `<div class="tf-slot-empty">+</div>`;
      }
      td.appendChild(div);
      tr.appendChild(td);
    });
    tbody.appendChild(tr);
  });
}

function abrirModalTF(diaIdx, hora, turnoExistente) {
  const modal = document.getElementById('modal-tf');
  if (!modal) return;
  tfEditKey = turnoExistente ? tfKey(diaIdx, hora) : null;

  document.getElementById('tf-modal-titulo').textContent = turnoExistente ? 'Editar turno fijo' : 'Agregar turno fijo';
  if (diaIdx !== null) document.getElementById('tf-dia').value = diaIdx;
  if (hora)    document.getElementById('tf-hora').value = hora;
  document.getElementById('tf-nombre').value  = turnoExistente?.nombre  || '';
  document.getElementById('tf-tel').value     = turnoExistente?.tel     || '';
  document.getElementById('tf-monto').value   = turnoExistente?.monto   || '';
  document.getElementById('tf-cancha').value  = turnoExistente?.cancha  || 'Fútbol 11';
  document.getElementById('tf-obs').value     = turnoExistente?.obs     || '';
  document.getElementById('tf-delete-btn').style.display = turnoExistente ? 'block' : 'none';
  modal.classList.add('open');
  setTimeout(() => document.getElementById('tf-nombre').focus(), 100);
}

function cerrarModalTF() {
  document.getElementById('modal-tf')?.classList.remove('open');
}

function guardarTF() {
  const nombre = document.getElementById('tf-nombre').value.trim();
  if (!nombre) { alert('Escribí el nombre del equipo.'); return; }
  const diaIdx = parseInt(document.getElementById('tf-dia').value);
  const hora   = document.getElementById('tf-hora').value;
  const key    = tfKey(diaIdx, hora);

  // Verificar conflicto (diferente al que estamos editando)
  const conflicto = turnosFijos.find(t => tfKey(t.diaIdx, t.hora) === key && tfKey(t.diaIdx, t.hora) !== tfEditKey);
  if (conflicto) {
    if (!confirm(`⚠️ ${TF_DIAS[diaIdx]} ${hora} ya está ocupado por "${conflicto.nombre}". ¿Reemplazar?`)) return;
    turnosFijos = turnosFijos.filter(t => tfKey(t.diaIdx, t.hora) !== key);
  }

  // Eliminar el que estamos editando si cambió de slot
  if (tfEditKey && tfEditKey !== key) {
    turnosFijos = turnosFijos.filter(t => tfKey(t.diaIdx, t.hora) !== tfEditKey);
  } else if (tfEditKey) {
    turnosFijos = turnosFijos.filter(t => tfKey(t.diaIdx, t.hora) !== tfEditKey);
  }

  turnosFijos.push({
    diaIdx, hora, nombre,
    tel:    document.getElementById('tf-tel').value.trim(),
    monto:  parseFloat(document.getElementById('tf-monto').value) || 0,
    cancha: document.getElementById('tf-cancha').value,
    obs:    document.getElementById('tf-obs').value.trim(),
  });

  localStorage.setItem('aldea_turnos_fijos', JSON.stringify(turnosFijos));
  cerrarModalTF();
  renderTurnosFijos();

  // Sincronizar con Sheets
  const url = localStorage.getItem('aldea_sheet_url');
  if (url) {
    fetch(url, { method:'POST', mode:'no-cors', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ tipo:'turno_fijo', turnosFijos }) }).catch(() => {});
  }
}

function eliminarTF() {
  if (!tfEditKey) return;
  if (!confirm('¿Eliminar este turno fijo?')) return;
  turnosFijos = turnosFijos.filter(t => tfKey(t.diaIdx, t.hora) !== tfEditKey);
  localStorage.setItem('aldea_turnos_fijos', JSON.stringify(turnosFijos));
  cerrarModalTF();
  renderTurnosFijos();
}

