// ── TICKET DE MESA ──
function imprimirTicketMesa(mesaData, metodo){
  const ahora = new Date();
  const hora = ahora.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'});
  const fecha = ahora.toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'numeric'});

  let lineas = '';
  let total = 0;
  Object.values(mesaData.items).forEach(it => {
    const sub = it.precio * it.qty;
    total += sub;
    const nombre = it.nombre.length > 22 ? it.nombre.slice(0,20)+'…' : it.nombre;
    lineas += `
      <div class="fila">
        <span class="izq">${it.qty}x ${nombre}</span>
        <span class="der">${fmtT(sub)}</span>
      </div>`;
  });

  const html = `
    <div class="tc">
      <div class="logo-txt">ALDEA DEL VALLE</div>
      <div class="chico">Cantina</div>
    </div>
    <hr class="sep-sol"/>
    <div class="fila chico"><span>${fecha}</span><span>${hora}</span></div>
    <div class="bold" style="margin:4px 0;">${mesaData.nombre}</div>
    <hr class="sep"/>
    <div class="chico bold" style="margin-bottom:4px;">DETALLE</div>
    ${lineas}
    <hr class="sep-sol"/>
    <div class="total-box">
      <div class="chico">TOTAL</div>
      <div class="monto">${fmtT(total)}</div>
    </div>
    <div class="tc">
      <div class="metodo-badge">${metodo === 'efectivo' ? '💵 EFECTIVO' : '📲 TRANSFERENCIA'}</div>
    </div>
    <hr class="sep" style="margin-top:10px;"/>
    <div class="tc chico" style="margin-top:4px;">¡Gracias por tu visita!</div>
    <div style="height:20mm;"></div>
  `;
  abrirVentanaImpresion(html);
}

