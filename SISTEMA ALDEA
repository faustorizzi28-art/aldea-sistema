  .res-resumen-box{background:var(--azul);border-radius:14px;padding:20px;color:white;margin:14px 0;}
  .res-resumen-box h3{font-size:16px;font-weight:600;margin-bottom:12px;}
  .res-linea{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.2);}
