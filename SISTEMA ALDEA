function guardarPrecios(){
  localStorage.setItem('aldea_carta',JSON.stringify(carta));preciosModificados=false;
  document.querySelectorAll('.precio-input.modified').forEach(i=>i.classList.remove('modified'));
  const url=localStorage.getItem('aldea_carta_url');
  if(url)fetch(url,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify({tipo:'precios',carta})}).catch(()=>{});
  document.getElementById('save-msg').textContent='✅ Precios guardados';setTimeout(()=>document.getElementById('save-bar').classList.remove('visible'),2000);
