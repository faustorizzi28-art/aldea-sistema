let canchas = JSON.parse(localStorage.getItem('aldea_canchas') || '[]');
let semanaOffset = 0;
let diaSeleccionado = new Date().toISOString().split('T')[0];
let canchaEditIdx = null;

function getSemanaFechas(offset) {
  const hoy = new Date();
  const diaSemana = hoy.getDay(); // 0=dom
  const lunes = new Date(hoy);
  lunes.setDate(hoy.getDate() - (diaSemana === 0 ? 6 : diaSemana - 1) + offset * 7);
  const dias = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(lunes);
    d.setDate(lunes.getDate() + i);
    dias.push(d);
  }
  return dias;
}

function renderCalendarioCanchas() {
  const dias = getSemanaFechas(semanaOffset);
  const primerDia = dias[0];
  const ultimoDia = dias[6];
  const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  document.getElementById('cal-titulo').textContent = 
    `${primerDia.getDate()} ${meses[primerDia.getMonth()]} – ${ultimoDia.getDate()} ${meses[ultimoDia.getMonth()]}`;
  
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  const labels = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
  
  // Headers
  const headersEl = document.getElementById('cal-headers');
  headersEl.innerHTML = '';
  labels.forEach(l => {
    const el = document.createElement('div');
    el.className = 'cal-dia-header';
    el.textContent = l;
    headersEl.appendChild(el);
  });
  
  // Días
  const diasEl = document.getElementById('cal-dias');
  diasEl.innerHTML = '';
  dias.forEach(d => {
    const fechaStr = d.toISOString().split('T')[0];
    const reservasDia = canchas.filter(c => c.fecha === fechaStr);
    const esHoy = d.getTime() === hoy.getTime();
    const esSel = fechaStr === diaSeleccionado;
    
    const el = document.createElement('div');
    el.className = 'cal-dia' + (esHoy ? ' hoy' : '') + (esSel ? ' seleccionado' : '');
    el.onclick = () => { diaSeleccionado = fechaStr; renderCalendarioCanchas(); renderSlotsCanchas(); };
    el.innerHTML = `<div class="cal-num">${d.getDate()}</div>` +
      reservasDia.slice(0,3).map(r => 
        `<div class="cal-dot" style="background:${r.estado==='pagado'?'#1A7A55':'#C0392B'}"></div>`
      ).join('');
    diasEl.appendChild(el);
  });
  
  renderSlotsCanchas();
}

function renderSlotsCanchas() {
  const d = new Date(diaSeleccionado + 'T12:00:00');
  const dias = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  document.getElementById('cancha-dia-titulo').textContent = 
    `${dias[d.getDay()]} ${d.getDate()} de ${meses[d.getMonth()]}`;
  
  const reservasDia = canchas.filter(c => c.fecha === diaSeleccionado)
    .sort((a,b) => a.horaIni.localeCompare(b.horaIni));
  
  const container = document.getElementById('cancha-slots');
  container.innerHTML = '';
  
  if (reservasDia.length === 0) {
    container.innerHTML = `<div style="text-align:center;padding:30px;color:var(--gris);">
      <div style="font-size:36px;margin-bottom:8px;">🎾</div>
      <div style="font-size:13px;">No hay reservas este día</div>
      <div style="font-size:12px;margin-top:4px;">Tocá "+ Reservar" para agregar</div>
    </div>`;
    return;
  }
  
  reservasDia.forEach(r => {
    const idx = canchas.indexOf(r);
    const slot = document.createElement('div');
    slot.className = 'cancha-slot ' + (r.estado === 'pagado' ? 'libre' : 'ocupado');
    slot.onclick = () => abrirModalCancha(idx);
    slot.innerHTML = `
      <div class="slot-hora">${r.horaIni} – ${r.horaFin}</div>
      <div class="slot-info">
        <div class="slot-nombre">${r.nombre}</div>
        <div class="slot-detalle">${r.tel || ''}${r.obs ? ' · '+r.obs : ''}</div>
      </div>
      <div>
        ${r.monto ? `<div style="font-family:'DM Mono',monospace;font-size:13px;font-weight:600;color:var(--verde);margin-bottom:3px;">${fmt(r.monto)}</div>` : ''}
        <div class="slot-badge">${r.estado === 'pagado' ? '✅ Pagado' : '⏳ Pendiente'}</div>
      </div>`;
    container.appendChild(slot);
  });
}

function cambiarSemana(delta) {
  semanaOffset += delta;
  renderCalendarioCanchas();
}

