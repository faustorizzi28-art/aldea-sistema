  /* Modal turno fijo */
  .modal-tf{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:50;display:none;align-items:flex-end;justify-content:center;}
  .modal-tf.open{display:flex;}
  .modal-tf .modal-box{background:white;border-radius:20px 20px 0 0;padding:24px 20px 36px;width:100%;max-width:540px;}

</style>
