function resCalcPrecio() {
  const lista = resPrecioLista || 0;
  const real = parseFloat(document.getElementById('res-precio-real')?.value) || lista;
  const senia = parseFloat(document.getElementById('res-senia')?.value) || 0;
  const desc = lista > 0 ? Math.round((1 - real/lista)*100) : 0;
  const saldo = Math.max(0, real - senia);
  const dd = document.getElementById('res-display-desc');
  const ds = document.getElementById('res-display-saldo');
  if (dd) dd.textContent = desc + '%';
  if (ds) ds.textContent = fmt(saldo);
}

function resGoTo(n) {
  document.querySelectorAll('#mod-reservas .panel').forEach((p,i) => p.classList.toggle('active', i+1===n));
  for(let i=1;i<=4;i++){
    const sc = document.getElementById('rsc'+i);
    const sl = document.getElementById('rsl'+i);
    if(sc){ sc.classList.toggle('active',i===n); sc.classList.toggle('done',i<n); }
    if(sl && i<4) sl.classList.toggle('done',i<n);
  }
  if (n===4) resRenderResumen();
  window.scrollTo(0,0);
}

