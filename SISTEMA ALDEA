  .evp-acciones{display:flex;gap:6px;padding:8px 14px;border-top:1px solid var(--gris-claro);}
  .evp-btn{flex:1;padding:8px;border-radius:8px;border:1.5px solid var(--borde);background:white;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;text-align:center;transition:all .15s;}
  .evp-btn:active{transform:scale(.97);}
  .evp-btn.wa{border-color:#25D366;color:#25D366;}
  .evp-btn.wa:active{background:#E8F9EE;}
