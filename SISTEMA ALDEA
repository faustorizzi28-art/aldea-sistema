function descartarPrecios(){carta=JSON.parse(localStorage.getItem('aldea_carta')||'null')||JSON.parse(JSON.stringify(cartaInicial));renderCartaPrecios();document.getElementById('save-bar').classList.remove('visible');}
async function sincronizarDesdeSheets(){
  const url=localStorage.getItem('aldea_carta_url');const badge=document.getElementById('sync-status');
  if(!url){badge.className='sync-badge err';badge.textContent='sin URL';alert('Configurá la URL en Config.');return;}
  badge.className='sync-badge loading';badge.textContent='sincronizando…';
  try{const res=await fetch(url+'?t='+Date.now());const data=await res.json();
    if(data.ok&&data.items&&data.items.length>0){
      const nueva={};data.items.forEach(item=>{if(!nueva[item.cat])nueva[item.cat]=[];nueva[item.cat].push({n:item.nombre,p:parseInt(item.precio)||0});});
      Object.keys(cartaInicial).forEach(cat=>{if(!nueva[cat])nueva[cat]=cartaInicial[cat];});
      carta=nueva;localStorage.setItem('aldea_carta',JSON.stringify(carta));renderCartaPrecios();badge.className='sync-badge ok';badge.textContent='✓ actualizado';alert('✅ Precios actualizados.');
    }else{badge.className='sync-badge err';badge.textContent='error';alert('No se encontraron precios.');}
  }catch(e){badge.className='sync-badge err';badge.textContent='sin conexión';}
}

