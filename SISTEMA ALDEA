function confirmarCierreEImprimir(){
  if(mesaActual===null)return;
  const mesa = mesas[mesaActual];
  const total = calcTotalMesa(mesaActual);
  if(total===0){alert('Esta mesa no tiene pedidos.');return;}
  const mesaSnap = {nombre: mesa.nombre, items: JSON.parse(JSON.stringify(mesa.items))};
  const metodo = metodoSeleccionado;
  // Guardar en historial
  historialTurno.push({nombre:mesa.nombre,total,metodo,items:JSON.parse(JSON.stringify(mesa.items)),timestamp:new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})});
  actualizarCajaDesdeHistorial();
  mesas[mesaActual].items={};
  cerrarModal();
  volverAMesas();
  // Imprimir después de cerrar el modal
  setTimeout(()=>imprimirTicketMesa(mesaSnap, metodo), 300);
}


