let proximosCache = [];
let filtroProxActual = 'todos';

const MESES_SHORT = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
const DIAS_SHORT  = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
const MESES_LONG  = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const DIAS_LONG   = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];

function diasHastaFecha(fechaStr) {
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  const d = new Date(fechaStr + 'T12:00:00');
  return Math.round((d - hoy) / 86400000);
}

function alertaProx(dias) {
  if (dias < 0)  return { txt: '✅ Pasado', cls: 'ok' };
  if (dias === 0) return { txt: '🔴 HOY', cls: 'hoy' };
  if (dias === 1) return { txt: '🔴 MAÑANA', cls: 'hoy' };
  if (dias <= 3)  return { txt: `🟡 En ${dias} días`, cls: 'pronto' };
  if (dias <= 7)  return { txt: '🟡 Esta semana', cls: 'pronto' };
  return { txt: `🟢 En ${dias} días`, cls: 'ok' };
}

function estadoProxStyle(estado) {
  const map = {
    '🔵 Consulta nueva': 'background:#DBEAFE;color:#1A5F9E',
    '🟠 Esperando seña': 'background:#FEF3E7;color:#E67E22',
    '🟢 Confirmado': 'background:#E8F5EF;color:#1A7A55',
    '🟣 Recordatorio enviado': 'background:#F3E8FF;color:#6A0DAD',
    '⚫ Finalizado': 'background:#F2F2F2;color:#6B6B6B',
    '❌ Cancelado': 'background:#FDECEA;color:#C0392B',
  };
  return map[estado] || 'background:#F2F2F2;color:#6B6B6B';
}

function colorFecha(dias) {
  if (dias <= 1) return '#C0392B';
  if (dias <= 7) return '#E67E22';
  return '#1A5F9E';
}

function fmtProx(n) {
  if (!n && n !== 0) return '—';
  return '$' + Math.round(n).toLocaleString('es-AR');
}

function setFiltroProx(filtro, el) {
  filtroProxActual = filtro;
  document.querySelectorAll('.prox-fpill').forEach(p => p.classList.remove('active'));
  if (el) el.classList.add('active');
  renderProximos(proximosCache);
}

async function cargarProximosEventos() {
  const url = localStorage.getItem('aldea_sheet_url');
  const bar = document.getElementById('prox-sync-bar');
  const msg = document.getElementById('prox-sync-msg');
  
  // Primero mostrar eventos locales
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  const locales = (JSON.parse(localStorage.getItem('aldea_eventos') || '[]'))
    .filter(e => new Date(e.fecha + 'T12:00:00') >= hoy && e.estado !== '❌ Cancelado')
    .sort((a,b) => new Date(a.fecha) - new Date(b.fecha));

  if (!url) {
    proximosCache = locales;
    renderProximos(proximosCache);
    msg.textContent = `${locales.length} eventos locales (configurá URL para sincronizar)`;
    return;
  }

  msg.textContent = '⏳ Sincronizando con Google Sheets…';
  try {
    const res = await fetch(url + '?tipo=eventos&t=' + Date.now());
    const data = await res.json();
    if (data.ok && data.eventos && data.eventos.length > 0) {
      // Merge: Sheets + locales, sin duplicar
      const sheetsEvs = data.eventos.filter(e =>
        new Date(e.fecha + 'T12:00:00') >= hoy && e.estado !== '❌ Cancelado'
      );
      const merged = [...sheetsEvs];
      locales.forEach(loc => {
        const existe = merged.find(e => e.fecha===loc.fecha && e.turno===loc.turno && e.nombre===loc.nombre);
        if (!existe) merged.push(loc);
      });
      merged.sort((a,b) => new Date(a.fecha) - new Date(b.fecha));
      proximosCache = merged;
      msg.textContent = `✅ ${merged.length} eventos · ${new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})}`;
      bar.style.background = 'var(--verde-claro)';
      bar.querySelector('span').style.color = 'var(--verde)';
    } else {
      proximosCache = locales;
      msg.textContent = `📋 ${locales.length} eventos locales`;
    }
    renderProximos(proximosCache);
  } catch(e) {
    proximosCache = locales;
    renderProximos(proximosCache);
    msg.textContent = `⚠️ Sin conexión — mostrando ${locales.length} locales`;
    bar.style.background = 'var(--rojo-claro)';
    bar.querySelector('span').style.color = 'var(--rojo)';
  }
}

function renderProximos(lista) {
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  let filtrada = lista.slice();

  if (filtroProxActual === 'hoy') {
    filtrada = filtrada.filter(e => diasHastaFecha(e.fecha) === 0);
  } else if (filtroProxActual === 'semana') {
    filtrada = filtrada.filter(e => diasHastaFecha(e.fecha) <= 7 && diasHastaFecha(e.fecha) >= 0);
  } else if (filtroProxActual === 'pileta') {
    filtrada = filtrada.filter(e => e.pileta === 'Si');
  } else if (filtroProxActual !== 'todos') {
    filtrada = filtrada.filter(e => e.estado === filtroProxActual);
  }

  // KPIs
  const total = lista.length;
  const saldoTotal = lista.reduce((a,e) => a + Math.max(0,(e.monto||0)-(e.senia||0)), 0);
  const semana = lista.filter(e => diasHastaFecha(e.fecha) <= 7 && diasHastaFecha(e.fecha) >= 0).length;
  document.getElementById('pk-total').textContent = total;
  document.getElementById('pk-saldo').textContent = fmtProx(saldoTotal);
  document.getElementById('pk-semana').textContent = semana;

  const container = document.getElementById('prox-lista');
  if (filtrada.length === 0) {
    container.innerHTML = `<div style="text-align:center;padding:48px 20px;color:var(--gris);">
      <div style="font-size:44px;margin-bottom:12px;">📅</div>
      <div style="font-size:14px;font-weight:500;">No hay eventos que coincidan</div>
      <div style="font-size:12px;margin-top:6px;">Tocá "🔄 Actualizar" para traer datos de Sheets</div>
    </div>`;
    return;
  }

  const html_parts = [];
  let seccionActual = '';

  filtrada.forEach(ev => {
    const d = new Date(ev.fecha + 'T12:00:00');
    const dias = diasHastaFecha(ev.fecha);
    const alerta = alertaProx(dias);
    const saldo = Math.max(0, (ev.monto||0) - (ev.senia||0));
    const colorFd = colorFecha(dias);

    let seccion = dias < 0 ? '✅ Pasados' : dias === 0 ? '🔴 Hoy' : dias <= 7 ? '🟡 Esta semana' : dias <= 30 ? '📅 Próximos 30 días' : '📆 Más adelante';
    if (seccion !== seccionActual) {
      html_parts.push(`<div class="prox-seccion-lbl">${seccion}</div>`);
      seccionActual = seccion;
    }

    const turnoLabel = ev.turno === 'M' ? '🌅 Mañana (9-14h)' : ev.turno === 'T' ? '🌆 Tarde (14-20h)' : ev.turno === 'N' ? '🌙 Noche (20-5h)' : (ev.turno||'');

    html_parts.push(`
    <div class="ev-prox-card">
      <div class="ev-prox-top">
        <div class="ev-prox-fecha" style="background:${colorFd}">
          <div class="epf-num">${d.getDate()}</div>
          <div class="epf-mes">${MESES_SHORT[d.getMonth()]}</div>
          <div class="epf-dia">${DIAS_SHORT[d.getDay()]}</div>
        </div>
        <div class="ev-prox-body">
          <div class="ev-prox-nombre">${ev.nombre || '—'}</div>
          <div class="ev-prox-chips">
            ${ev.turno ? `<span class="ep-chip turno">${turnoLabel}</span>` : ''}
            ${ev.tipo ? `<span class="ep-chip tipo">${ev.tipo}</span>` : ''}
            ${ev.pileta === 'Si' ? `<span class="ep-chip pileta">🏊 Pileta</span>` : ''}
            ${ev.tel ? `<span class="ep-chip tel">📱 ${ev.tel}</span>` : ''}
          </div>
          <div class="ev-prox-horario">🕐 ${ev.horarioIni||''}${ev.horarioFin?' – '+ev.horarioFin+' hs':''}</div>
          <div class="ev-prox-montos">
            ${ev.monto ? `<div class="ep-monto-item"><div class="ep-lbl">Monto total</div><div class="ep-val" style="color:var(--azul)">${fmtProx(ev.monto)}</div></div>` : ''}
            ${ev.senia ? `<div class="ep-monto-item"><div class="ep-lbl">Seña recibida</div><div class="ep-val" style="color:var(--verde)">${fmtProx(ev.senia)}</div></div>` : ''}
            ${saldo > 0 ? `<div class="ep-monto-item"><div class="ep-lbl">Saldo pendiente</div><div class="ep-val" style="color:var(--rojo);font-weight:700">${fmtProx(saldo)}</div></div>` : ''}
          </div>
        </div>
      </div>
      <div class="ev-prox-footer">
        <span class="ep-estado-badge" style="${estadoProxStyle(ev.estado)}">${ev.estado}</span>
        <span class="ep-alerta ${alerta.cls}">${alerta.txt}</span>
      </div>
      ${ev.obs ? `<div class="ev-prox-obs">📝 ${ev.obs}</div>` : ''}
    </div>`);
  });

  container.innerHTML = html_parts.join('');
}

