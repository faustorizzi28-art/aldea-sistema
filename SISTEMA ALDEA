  historialTurno.push({nombre:mesa.nombre,total,metodo:metodoSeleccionado,items:JSON.parse(JSON.stringify(mesa.items)),timestamp:new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})});
