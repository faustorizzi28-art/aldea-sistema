  .tf-slot.ocupado{background:var(--verde-claro);cursor:pointer;}
  .tf-slot.ocupado:hover{background:#D0EDE1;}
  .tf-slot-nombre{font-size:11px;font-weight:700;color:var(--verde);line-height:1.3;margin-bottom:2px;}
  .tf-slot-tel{font-size:10px;color:var(--gris);margin-bottom:1px;}
