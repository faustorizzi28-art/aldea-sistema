function precioEditado(input){const cat=input.dataset.cat,idx=parseInt(input.dataset.idx);carta[cat][idx].p=parseInt(input.value)||0;input.classList.add('modified');preciosModificados=true;document.getElementById('save-bar').classList.add('visible');}
