    div.innerHTML=`${qty>0?`<div class="qty-badge">${qty}</div>`:''}<div class="prod-ilustracion">${getIconoDisplay(item,cat)}</div><div class="prod-nombre">${item.n}</div><div class="prod-precio">${fmt(item.p)}</div>`;
    div.onclick=()=>agregarItem(cat,idx,item);
    grid.appendChild(div);
  });
