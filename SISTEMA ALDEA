function renderEventos() {
  const buscar = (document.getElementById('ev-buscar')?.value || '').toLowerCase();
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  
  let lista = eventos.slice();
  
  // Filtro
  if (filtroEvActual !== 'todos') {
    if (filtroEvActual === 'proximos') {
      lista = lista.filter(e => new Date(e.fecha) >= hoy);
    } else {
      lista = lista.filter(e => e.estado === filtroEvActual);
    }
  }
  if (buscar) {
    lista = lista.filter(e => 
      e.nombre.toLowerCase().includes(buscar) || 
      e.tipo.toLowerCase().includes(buscar) ||
      (e.tel||'').includes(buscar)
    );
  }
  
  // Ordenar por fecha desc
  lista.sort((a,b) => new Date(b.fecha) - new Date(a.fecha));
  
  // Contadores
  const confirmados = eventos.filter(e => e.estado === '🟢 Confirmado').length;
  const pendientes = eventos.filter(e => e.estado === '🟠 Esperando seña').length;
  const saldoTotal = eventos.filter(e => !['⚫ Finalizado','❌ Cancelado'].includes(e.estado))
    .reduce((a,e) => a + ((e.monto||0)-(e.senia||0)), 0);
  document.getElementById('ev-cnt-confirmados').textContent = confirmados;
  document.getElementById('ev-cnt-pendientes').textContent = pendientes;
  document.getElementById('ev-saldo-total').textContent = fmt(saldoTotal);

  const container = document.getElementById('ev-lista');
  const empty = document.getElementById('ev-empty');
  container.innerHTML = '';
  
  if (lista.length === 0) {
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  
  lista.forEach((ev, _) => {
    const idxReal = eventos.indexOf(ev);
    const d = new Date(ev.fecha + 'T12:00:00');
    const dias = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    const saldo = (ev.monto||0) - (ev.senia||0);
    const estadoCls = ESTADOS_EV[ev.estado] || 'finalizado';
    
    const card = document.createElement('div');
    card.className = 'ev-card';
    card.onclick = () => abrirModalEvento(idxReal);
    card.innerHTML = `
      <div class="ev-card-header">
        <div style="display:flex;align-items:center;gap:10px;flex:1;">
          <div class="ev-fecha-badge">
            <div class="dia-num">${d.getDate()}</div>
            <div class="dia-txt">${meses[d.getMonth()]}</div>
          </div>
          <div class="ev-info">
            <div class="ev-nombre">${ev.nombre}</div>
            <div class="ev-tipo">${ev.tipo} · ${ev.horarioIni||''}-${ev.horarioFin||''} · Pileta: ${ev.pileta||'No'}</div>
          </div>
          <div class="turno-badge ${ev.turno}">${ev.turno}</div>
        </div>
      </div>
      <div class="ev-card-body">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span class="ev-estado ${estadoCls}">${ev.estado}</span>
          <div style="text-align:right;">
            ${ev.monto ? `<div class="ev-monto">${fmt(ev.monto)}</div>` : ''}
            ${saldo > 0 ? `<div style="font-size:11px;color:var(--rojo);">Saldo: ${fmt(saldo)}</div>` : ''}
          </div>
        </div>
        ${ev.obs ? `<div style="margin-top:6px;font-size:11px;color:var(--gris);font-style:italic;">${ev.obs}</div>` : ''}
      </div>`;
    container.appendChild(card);
  });
}

function abrirModalEvento(idx) {
  evEditIdx = idx;
  const ev = idx !== null ? eventos[idx] : null;
  document.getElementById('modal-ev-titulo').textContent = ev ? 'Editar reserva' : 'Nueva reserva de evento';
  document.getElementById('ev-fecha').value = ev ? ev.fecha : new Date().toISOString().split('T')[0];
  document.getElementById('ev-turno').value = ev?.turno || 'T';
  document.getElementById('ev-nombre').value = ev?.nombre || '';
  document.getElementById('ev-tel').value = ev?.tel || '';
  document.getElementById('ev-tipo').value = ev?.tipo || 'Cumpleaños Adultos';
  document.getElementById('ev-hora-ini').value = ev?.horarioIni || '16:00';
  document.getElementById('ev-hora-fin').value = ev?.horarioFin || '20:00';
  document.getElementById('ev-pileta').value = ev?.pileta || 'No';
  document.getElementById('ev-monto').value = ev?.monto || '';
  document.getElementById('ev-senia').value = ev?.senia || '';
  document.getElementById('ev-estado').value = ev?.estado || '🔵 Consulta nueva';
  document.getElementById('ev-obs').value = ev?.obs || '';
  calcSaldoEv();
  document.getElementById('ev-delete-btn').style.display = ev ? 'block' : 'none';
  document.getElementById('ev-whatsapp-btn').style.display = ev ? 'block' : 'none';
  document.getElementById('modal-evento').classList.add('open');
}

function calcSaldoEv() {
  const m = parseFloat(document.getElementById('ev-monto').value) || 0;
  const s = parseFloat(document.getElementById('ev-senia').value) || 0;
  document.getElementById('ev-saldo-disp').textContent = fmt(Math.max(0, m - s));
}

function cerrarModalEvento() {
  document.getElementById('modal-evento').classList.remove('open');
}

function guardarEvento() {
  const nombre = document.getElementById('ev-nombre').value.trim();
  if (!nombre) { alert('Escribí el nombre del cliente.'); return; }
  const fecha = document.getElementById('ev-fecha').value;
  if (!fecha) { alert('Elegí una fecha.'); return; }
  
  const turno = document.getElementById('ev-turno').value;
  // Chequeo de conflicto de turno
  const conflicto = eventos.find((e, i) => 
    i !== evEditIdx && e.fecha === fecha && e.turno === turno &&
    !['❌ Cancelado'].includes(e.estado)
  );
  if (conflicto) {
    if (!confirm(`⚠️ Ya hay un evento en ese turno (${turno}) el ${fecha}: "${conflicto.nombre}". ¿Querés guardarlo igual?`)) return;
  }
  
  const ev = {
    fecha, turno, nombre,
    tel: document.getElementById('ev-tel').value.trim(),
    tipo: document.getElementById('ev-tipo').value,
    horarioIni: document.getElementById('ev-hora-ini').value,
    horarioFin: document.getElementById('ev-hora-fin').value,
    pileta: document.getElementById('ev-pileta').value,
    monto: parseFloat(document.getElementById('ev-monto').value) || 0,
    senia: parseFloat(document.getElementById('ev-senia').value) || 0,
    estado: document.getElementById('ev-estado').value,
    obs: document.getElementById('ev-obs').value.trim(),
    sincronizado: false,
    creado: new Date().toISOString(),
  };
  
  if (evEditIdx !== null) {
    ev.creado = eventos[evEditIdx].creado;
    eventos[evEditIdx] = ev;
  } else {
    eventos.push(ev);
  }
  
  localStorage.setItem('aldea_eventos', JSON.stringify(eventos));
  cerrarModalEvento();
  renderEventos();
  
  // Sincronizar con Sheets
  sincronizarEventoASheets(ev);
}

function eliminarEvento() {
  if (evEditIdx === null) return;
  if (!confirm('¿Eliminar esta reserva?')) return;
  eventos.splice(evEditIdx, 1);
  localStorage.setItem('aldea_eventos', JSON.stringify(eventos));
  cerrarModalEvento();
  renderEventos();
}

function enviarWhatsappEvento() {
  if (evEditIdx === null) return;
  const ev = eventos[evEditIdx];
  const d = new Date(ev.fecha + 'T12:00:00');
  const saldo = (ev.monto||0) - (ev.senia||0);
  const dias = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const fechaTxt = `${dias[d.getDay()]} ${d.getDate()} de ${meses[d.getMonth()]}`;
  
  let msg = `¡Hola ${ev.nombre}! 👋

Te recordamos que tu evento en *Aldea del Valle* está programado para:

📅 *${fechaTxt}*
🕐 *${ev.horarioIni} a ${ev.horarioFin} hs*
🎉 *${ev.tipo}*`;
  if (ev.pileta === 'Si') msg += `
🏊 Con pileta`;
  if (saldo > 0) msg += `

💰 *Saldo pendiente: ${fmt(saldo)}*
Recordá abonarlo el día del evento.`;
  msg += `

¡Los esperamos! 🌿`;
  
  const tel = ev.tel ? ev.tel.replace(/\D/g,'') : '';
