  if(n.includes('coca')) return 'coca';
  if(n.includes('sprite')) return 'sprite';
  if(n.includes('fanta')) return 'fanta';
  if(n.includes('cunnington')) return 'cunnington';
  if(n.includes('gatorade')) return 'gatorade';
  if(n.includes('speed')) return 'speed';
  if(n.includes('pritty')) return 'pritty';
  if(n.includes('agua')) return 'agua';
  if(n.includes('soda')) return 'soda';
  if(n.includes('cepita')) return 'cepita';
  if(n.includes('levite')) return 'levite';
  if(n.includes('café')||n.includes('cafe')) return 'cafe';
  if(n.includes('corona botell')||n.includes('coronita')) return 'coronita';
  if(n.includes('corona')) return 'cerveza';
  if(n.includes('stella')) return 'stella';
  if(n.includes('fernet')) return 'fernet';
  if(n.includes('gancia')) return 'gancia';
