async function sincronizarEventoASheets(ev) {
  const url = localStorage.getItem('aldea_sheet_url');
  if (!url) return;
  try {
    await fetch(url, {
      method: 'POST', mode: 'no-cors',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({tipo:'evento', ...ev})
    });
