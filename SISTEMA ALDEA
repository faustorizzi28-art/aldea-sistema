    container.appendChild(slot);
  });
}

async function crGuardarReserva() {
  const nombre=document.getElementById('cr-nombre')?.value.trim();
  if(!nombre){alert('Escribí el nombre.');return;}
  const fecha=document.getElementById('cr-fecha')?.value;
  if(!fecha){alert('Elegí una fecha.');return;}
  const horaIni=document.getElementById('cr-hora-ini')?.value;
  const horaFin=document.getElementById('cr-hora-fin')?.value;
  const conflicto=canchas.find((c,i)=>{
    if(c.fecha!==fecha)return false;
    return horaIni<c.horaFin&&horaFin>c.horaIni;
  });
  if(conflicto&&!confirm(`⚠️ Se superpone con "${conflicto.nombre}" (${conflicto.horaIni}-${conflicto.horaFin}). ¿Guardarlo igual?`))return;
  const r={
    fecha,horaIni,horaFin,nombre,
    tel:document.getElementById('cr-tel')?.value.trim()||'',
    cancha:document.getElementById('cr-cancha')?.value||'',
    tipoReserva:document.getElementById('cr-tipo')?.value||'',
    monto:parseFloat(document.getElementById('cr-monto')?.value)||0,
    senia:parseFloat(document.getElementById('cr-senia')?.value)||0,
    estado:document.getElementById('cr-estado')?.value||'pendiente',
    obs:document.getElementById('cr-obs')?.value.trim()||'',
    creado:new Date().toISOString()
  };
  canchas.push(r);
  diaSeleccionado=fecha;
  localStorage.setItem('aldea_canchas',JSON.stringify(canchas));
  alert(`✅ Reserva de "${nombre}" guardada.`);
  // Limpiar form
  ['cr-nombre','cr-tel','cr-obs'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['cr-monto','cr-senia'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  sincronizarCanchaASheets(r);
  setCrTab('calendario',document.querySelector('.cr-tab'));
}

