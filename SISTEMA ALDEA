  .horario-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-top:6px;}
  .horario-btn{border:1.5px solid var(--borde);border-radius:8px;padding:9px 10px;text-align:center;cursor:pointer;background:white;font-size:13px;font-family:'DM Mono',monospace;color:var(--gris-oscuro);transition:all .2s;}
