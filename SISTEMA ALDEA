function initMesas(){if(mesas.length===0){for(let i=0;i<MAX_MESAS;i++)mesas.push({nombre:'Mesa '+(i+1),items:{},cerrada:false});}}

// ─── PANEL MESAS ───
function renderPanelMesas(){
  initMesas();
  const grid=document.getElementById('mesas-grid');grid.innerHTML='';
  let totalAb=0;
  mesas.forEach((mesa,i)=>{
    const total=calcTotalMesa(i),count=contarItemsMesa(i);
    totalAb+=total;
    const card=document.createElement('div');
    const estado=count>0?'ocupada':'';
    card.className='mesa-card '+estado;
    card.onclick=()=>abrirMesa(i);
    card.innerHTML=`<div class="mesa-status"></div><div class="mesa-num">Mesa ${i+1}</div><div class="mesa-nombre">${mesa.nombre}</div><div class="mesa-total">${total>0?fmt(total):'Vacía'}</div>${count>0?`<div class="mesa-items-count">${count} ítem${count>1?'s':''}</div>`:''}`;
    grid.appendChild(card);
  });
  document.getElementById('total-turno-label').textContent='Total: '+fmt(totalAb+calcTotalHistorial());
  renderHistorial();
}
function calcTotalMesa(i){let t=0;Object.values(mesas[i].items).forEach(it=>t+=it.precio*it.qty);return t;}
function contarItemsMesa(i){let c=0;Object.values(mesas[i].items).forEach(it=>c+=it.qty);return c;}
function calcTotalHistorial(){return historialTurno.reduce((a,h)=>a+h.total,0);}

