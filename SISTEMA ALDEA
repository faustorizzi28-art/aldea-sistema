          <div class="input-prefix"><span>$</span><input type="number" id="i-comanda" placeholder="0" oninput="calcTotales()" readonly style="background:#E8F5EF;color:var(--verde);font-weight:600;"/></div>
          <div style="font-size:11px;color:var(--verde);margin-top:4px;" id="comanda-detalle"></div>
        </div>
        <div class="divider"></div>
