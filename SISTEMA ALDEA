function renderCmdProductos(cat){
  const grid=document.getElementById('cmd-productos-grid');grid.innerHTML='';
  carta[cat].forEach((item,idx)=>{
    const key=cat+'_'+idx;
    const it=mesaActual!==null?mesas[mesaActual].items[key]:null;
    const qty=it?it.qty:0;
    const div=document.createElement('div');
    div.className='prod-btn'+(qty>0?' tiene-qty':'');
