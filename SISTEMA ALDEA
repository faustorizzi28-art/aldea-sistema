      </div>
      <div class="btn-row"><button class="btn btn-primary" onclick="goTo(2)">Continuar →</button></div>
    </div>
    <div class="panel" id="panel2">
      <div class="section" style="margin-top:20px;">
        <div class="section-header"><span class="section-icon">💵</span><div><div class="section-title">Ingresos del turno</div><div class="section-sub">Todo lo que entró de dinero</div></div></div>
        <div class="field"><label>Efectivo — Cantina</label><div class="input-prefix"><span>$</span><input type="number" id="i-ef-cantina" placeholder="0" oninput="calcTotales()"/></div></div>
        <div class="field"><label>Transferencia / QR — Cantina</label><div class="input-prefix"><span>$</span><input type="number" id="i-qr-cantina" placeholder="0" oninput="calcTotales()"/></div></div>
