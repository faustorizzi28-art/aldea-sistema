function cerrarModalCancha() {
  document.getElementById('modal-cancha').classList.remove('open');
}

function guardarCancha() {
  const nombre = document.getElementById('cn-nombre').value.trim();
  if (!nombre) { alert('Escribí el nombre o grupo.'); return; }
  const fecha = document.getElementById('cn-fecha').value;
  if (!fecha) { alert('Elegí una fecha.'); return; }
  const horaIni = document.getElementById('cn-hora-ini').value;
  const horaFin = document.getElementById('cn-hora-fin').value;
  
  // Chequeo solapamiento
  const conflicto = canchas.find((c, i) => {
    if (i === canchaEditIdx || c.fecha !== fecha) return false;
    return horaIni < c.horaFin && horaFin > c.horaIni;
  });
  if (conflicto) {
    if (!confirm(`⚠️ Se superpone con "${conflicto.nombre}" (${conflicto.horaIni}-${conflicto.horaFin}). ¿Guardarlo igual?`)) return;
  }
  
  const r = {
    fecha, horaIni, horaFin, nombre,
    tel: document.getElementById('cn-tel').value.trim(),
    monto: parseFloat(document.getElementById('cn-monto').value) || 0,
    estado: document.getElementById('cn-estado').value,
    obs: document.getElementById('cn-obs').value.trim(),
    creado: new Date().toISOString(),
  };
  
  if (canchaEditIdx !== null) {
    r.creado = canchas[canchaEditIdx].creado;
    canchas[canchaEditIdx] = r;
  } else {
    canchas.push(r);
  }
  
  diaSeleccionado = fecha;
  localStorage.setItem('aldea_canchas', JSON.stringify(canchas));
  cerrarModalCancha();
  renderCalendarioCanchas();
  
  // Sincronizar con Sheets
  sincronizarCanchaASheets(r);
}

function eliminarCancha() {
  if (canchaEditIdx === null) return;
  if (!confirm('¿Eliminar esta reserva de cancha?')) return;
  canchas.splice(canchaEditIdx, 1);
  localStorage.setItem('aldea_canchas', JSON.stringify(canchas));
  cerrarModalCancha();
  renderCalendarioCanchas();
}

async function sincronizarCanchaASheets(r) {
  const url = localStorage.getItem('aldea_sheet_url');
  if (!url) return;
  try {
    await fetch(url, {
      method: 'POST', mode: 'no-cors',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({tipo:'cancha', ...r})
    });
  } catch(e) { console.log('Sheets sync error:', e); }
}



