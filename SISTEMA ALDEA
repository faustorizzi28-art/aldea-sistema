  if(n.includes('vodka')||n.includes('skyy')||n.includes('smirnoff')) return 'vodka';
  if(n.includes('promo')) return 'promo';
  if(n.includes('hielo')) return 'hielo';
  if(n.includes('carbón')||n.includes('carbon')) return 'carbon';
  if(n.includes('leña')||n.includes('lena')) return 'lena';
  if(n.includes('cubierto')) return 'cubiertos';
  if(n.includes('entrada')) return 'entrada';
  if(n.includes('caramelo')) return 'caramelo';
  if(n.includes('chupetin')) return 'chupetin';
  if(n.includes('gomita')) return 'gomitas';
  if(n.includes('turrón')||n.includes('turron')) return 'turron';
  if(n.includes('budín')||n.includes('budin')) return 'budin';
  if(n.includes('pastelito')) return 'pastelito';
  if(n.includes('panqueque')) return 'panqueque';
  if(n.includes('tic')) return 'tictak';
  if(cat==='kiosco'||cat==='dulces') return 'kiosco';
  if(cat==='gaseosas') return 'gaseosa';
  return 'default';
}

function getSvg(nombre, cat){
  const key = nombre && nombre.startsWith('__emoji__') ? null : getIconoKey(nombre||'',cat||'');
  if(key && ICONOS[key]) return ICONOS[key];
  return ICONOS['default'];
}

function getIconoDisplay(item, cat){
  if(item.emoji) return `<div style="font-size:32px;line-height:52px;text-align:center;width:52px;height:52px;">${item.emoji}</div>`;
  return getSvg(item.n, cat);
}
function getIconoDisplaySmall(item, cat){
  if(item.emoji) return `<div style="font-size:18px;line-height:24px;text-align:center;width:24px;height:24px;">${item.emoji}</div>`;
  const key=getIconoKey(item.n||'',cat||'');
  const svg=ICONOS[key]||ICONOS['default'];
  return `<div style="width:24px;height:24px;">${svg}</div>`;
}

