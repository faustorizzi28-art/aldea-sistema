}

function agregarItem(cat,idx,item){
  if(mesaActual===null)return;
  const key=cat+'_'+idx;const mesa=mesas[mesaActual];
  if(!mesa.items[key])mesa.items[key]={qty:0,nombre:item.n,precio:item.p,cat,emoji:item.emoji};
  mesa.items[key].qty++;
  const btn=document.getElementById('pb-'+key);
  if(btn){btn.classList.add('tiene-qty');let b=btn.querySelector('.qty-badge');if(!b){b=document.createElement('div');b.className='qty-badge';btn.prepend(b);}b.textContent=mesa.items[key].qty;}
  renderMesaTicket();
  document.getElementById('mesa-ticket-bar').classList.remove('collapsed');
}

function cambiarQty(key,delta){
  if(mesaActual===null)return;const mesa=mesas[mesaActual];
  if(!mesa.items[key])return;
  mesa.items[key].qty+=delta;
  if(mesa.items[key].qty<=0)delete mesa.items[key];
  renderMesaTicket();
  const btn=document.getElementById('pb-'+key);
  if(btn){const qty=mesa.items[key]?mesa.items[key].qty:0;btn.classList.toggle('tiene-qty',qty>0);let b=btn.querySelector('.qty-badge');if(qty>0){if(!b){b=document.createElement('div');b.className='qty-badge';btn.prepend(b);}b.textContent=qty;}else if(b)b.remove();}
}

function renderMesaTicket(){
  if(mesaActual===null)return;const mesa=mesas[mesaActual];
  const lineas=document.getElementById('tk-lineas');lineas.innerHTML='';
  let total=0,count=0;
  Object.entries(mesa.items).forEach(([key,it])=>{
    const sub=it.precio*it.qty;total+=sub;count+=it.qty;
    const div=document.createElement('div');div.className='tk-linea';
    div.innerHTML=`<div class="tk-icono">${getIconoDisplaySmall(it,it.cat)}</div><div class="tk-nombre">${it.nombre}</div><div class="tk-qty-ctrl"><button onclick="cambiarQty('${key}',-1)">−</button><span class="tk-qty-num">${it.qty}</span><button onclick="cambiarQty('${key}',1)">+</button></div><div class="tk-sub">${fmt(sub)}</div>`;
    lineas.appendChild(div);
  });
  document.getElementById('tk-total').textContent=fmt(total);
  document.getElementById('tk-count').textContent=count>0?count+' ítem'+(count>1?'s':''):'Sin pedidos';
  if(count===0)document.getElementById('mesa-ticket-bar').classList.add('collapsed');
}

function toggleMesaTicket(){const bar=document.getElementById('mesa-ticket-bar');if(mesaActual===null||contarItemsMesa(mesaActual)===0)return;bar.classList.toggle('collapsed');}
function limpiarMesaActual(){if(mesaActual===null)return;if(!confirm('¿Limpiar todos los pedidos?'))return;mesas[mesaActual].items={};renderCmdProductos(catActualCmd);renderMesaTicket();document.getElementById('mesa-ticket-bar').classList.add('collapsed');}

