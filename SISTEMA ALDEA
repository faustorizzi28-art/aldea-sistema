  addBtn.className='prod-btn add-prod';
  addBtn.innerHTML=`<div style="font-size:28px;color:var(--gris);">+</div><div class="prod-nombre" style="color:var(--gris);">Agregar producto</div>`;
  addBtn.onclick=()=>abrirModalNP('comanda');
