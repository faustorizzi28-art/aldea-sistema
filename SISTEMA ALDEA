  .evp-mes-header .mes-line{flex:1;height:1px;background:var(--borde);}
  .evp-mes-label{font-size:12px;font-weight:700;color:var(--gris);text-transform:uppercase;letter-spacing:.08em;white-space:nowrap;}
  .evp-card{background:white;border-radius:14px;border-left:4px solid var(--azul);border-top:1px solid var(--borde);border-right:1px solid var(--borde);border-bottom:1px solid var(--borde);margin-bottom:10px;overflow:hidden;}
  .evp-card.hoy{border-left-color:var(--rojo);}
  .evp-card.pronto{border-left-color:var(--amarillo);}
  .evp-card.confirmado{border-left-color:var(--verde);}
  .evp-top{display:flex;gap:0;}
  .evp-fecha-col{padding:14px 12px;text-align:center;min-width:62px;border-right:1px solid var(--gris-claro);}
  .evp-fecha-col .ef-num{font-size:26px;font-weight:700;line-height:1;color:var(--gris-oscuro);}
  .evp-fecha-col .ef-mes{font-size:10px;font-weight:600;color:var(--gris);text-transform:uppercase;margin-top:2px;}
  .evp-fecha-col .ef-dia{font-size:9px;color:var(--gris);margin-top:1px;}
  .evp-fecha-col .ef-dias-badge{margin-top:6px;font-size:9px;font-weight:700;padding:2px 6px;border-radius:8px;display:inline-block;}
  .evp-body{flex:1;padding:12px 14px;}
  .evp-nombre{font-size:15px;font-weight:700;color:var(--gris-oscuro);margin-bottom:5px;}
  .evp-chips{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:7px;}
  .evp-chip{font-size:11px;font-weight:500;padding:2px 9px;border-radius:10px;}
  .evp-chip.turno{background:var(--amarillo-claro);color:var(--amarillo);}
  .evp-chip.tipo{background:var(--azul-claro);color:var(--azul);}
  .evp-chip.pileta{background:var(--verde-claro);color:var(--verde);}
  .evp-horario{font-size:12px;color:var(--gris);margin-bottom:8px;}
  .evp-tel{font-size:12px;color:var(--gris);margin-bottom:8px;}
  .evp-montos-row{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
  .evp-monto-box{background:var(--gris-claro);border-radius:8px;padding:7px 8px;text-align:center;}
  .evp-monto-box .emb-lbl{font-size:9px;color:var(--gris);margin-bottom:2px;text-transform:uppercase;letter-spacing:.04em;}
  .evp-monto-box .emb-val{font-family:'DM Mono',monospace;font-size:12px;font-weight:700;}
  .evp-footer{padding:8px 14px;background:var(--gris-claro);display:flex;align-items:center;justify-content:space-between;}
