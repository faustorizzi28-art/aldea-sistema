  if(!container)return;
  if(reservasDia.length===0){
    container.innerHTML=`<div style="text-align:center;padding:24px;color:var(--gris);"><div style="font-size:32px;margin-bottom:8px;">🎾</div><div style="font-size:13px;">Sin reservas este día</div></div>`;
